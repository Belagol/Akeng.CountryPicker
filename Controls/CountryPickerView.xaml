<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="AkengCountryPicker.Controls.CountryPickerView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AkengCountryPicker.Controls"
    xmlns:models="clr-namespace:AkengCountryPicker.Models"
    x:Name="root">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">

        <SearchBar
            x:Name="SearchCountryBar"
            IsVisible="{Binding ShowSearchBar, Source={x:Reference root}}"
            Placeholder="{Binding Placeholder, Source={x:Reference root}}"
            Text="{Binding SearchText, Source={x:Reference root}, Mode=TwoWay}"
            TextChanged="OnSearchTextChanged" />

        <Label
            x:Name="EmptyMessageLabel"
            Grid.Row="1"
            HorizontalOptions="Center"
            IsVisible="False"
            Text="{Binding EmptyMessage, Source={x:Reference root}}"
            TextColor="Gray" />

        <CollectionView
            x:Name="CountriesCollectionView"
            Grid.Row="2"
            IsGrouped="True"
            ItemSizingStrategy="MeasureFirstItem"
            SelectionChanged="OnCountrySelected"
            SelectionMode="Single">

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="models:CountryGroup">
                    <Grid Padding="12,10,12,6">
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="{Binding Title}"
                            TextColor="{AppThemeBinding Light=#555555,
                                                        Dark=#CCCCCC}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CountryInfo">

                    <Grid
                        Padding="12,6"
                        ColumnDefinitions="40,*,60,Auto,44"
                        HeightRequest="52">

                        <Label
                            FontSize="24"
                            IsVisible="{Binding ShowEmoji, Source={RelativeSource AncestorType={x:Type controls:CountryPickerView}}}"
                            Text="{Binding FlagEmoji}"
                            VerticalOptions="Center" />

                        <VerticalStackLayout
                            Grid.Column="1"
                            Margin="8,0"
                            Spacing="1"
                            VerticalOptions="Center">

                            <Label
                                FontSize="16"
                                LineBreakMode="TailTruncation"
                                Text="{Binding Name}" />

                            <Label
                                FontSize="12"
                                IsVisible="{Binding ShowNativeName, Source={RelativeSource AncestorType={x:Type controls:CountryPickerView}}}"
                                LineBreakMode="TailTruncation"
                                Text="{Binding NativeName}"
                                TextColor="Gray" />

                        </VerticalStackLayout>

                        <VerticalStackLayout
                            Grid.Column="2"
                            Margin="8,0"
                            Spacing="1"
                            VerticalOptions="Center">

                            <Label
                                FontSize="13"
                                IsVisible="{Binding ShowIso2, Source={RelativeSource AncestorType={x:Type controls:CountryPickerView}}}"
                                Text="{Binding Iso2}"
                                TextColor="Gray" />

                            <Label
                                FontSize="13"
                                IsVisible="{Binding ShowIso3, Source={RelativeSource AncestorType={x:Type controls:CountryPickerView}}}"
                                Text="{Binding Iso3}"
                                TextColor="Gray" />

                        </VerticalStackLayout>

                        <Label
                            Grid.Column="3"
                            FontSize="15"
                            IsVisible="{Binding ShowDialCode, Source={RelativeSource AncestorType={x:Type controls:CountryPickerView}}}"
                            Text="{Binding DialCode}"
                            VerticalOptions="Center" />

                        <Button
                            Grid.Column="4"
                            Padding="0"
                            BackgroundColor="Transparent"
                            Clicked="OnFavoriteClicked"
                            FontSize="22"
                            IsVisible="{Binding AllowFavoriteSelection, Source={RelativeSource AncestorType={x:Type controls:CountryPickerView}}}"
                            Text="{Binding FavoriteIcon}"
                            VerticalOptions="Center" />

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

